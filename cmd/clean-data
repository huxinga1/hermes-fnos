#!/bin/bash
# Hermes AI Agent - 彻底清除数据
# 警告：此脚本会删除所有应用数据（venv、WebUI、工作空间等）
# 卸载后运行此脚本可以彻底清除残留数据

LOG_FILE="${TRIM_PKGVAR}/info.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

log_msg "===== 开始清除数据 ====="

echo "┌─────────────────────────────────────────────────┐"
echo "│ ⚠  彻底清除 Hermes AI Agent 所有数据          │"
echo "├─────────────────────────────────────────────────┤"
echo "│ 以下目录将被删除:                               │"
echo "│   ${TRIM_PKGVAR}              │"
echo "│   ${TRIM_PKGETC}                │"
echo "└─────────────────────────────────────────────────┘"
echo ""

# 检查 TRIM_PKGVAR 是否有效，避免误删
if [ -z "${TRIM_PKGVAR}" ] || [ "${TRIM_PKGVAR}" = "/" ]; then
    echo "❌ 错误: TRIM_PKGVAR 无效，中止操作"
    exit 1
fi
if [ -z "${TRIM_PKGETC}" ] || [ "${TRIM_PKGETC}" = "/" ]; then
    echo "❌ 错误: TRIM_PKGETC 无效，中止操作"
    exit 1
fi

# 删除 var/ 目录
if [ -d "${TRIM_PKGVAR}" ]; then
    echo "→ 删除应用数据: ${TRIM_PKGVAR}"
    rm -rf "${TRIM_PKGVAR}"
    echo "   ✓ 已删除"
fi

# 删除 etc/ 目录
if [ -d "${TRIM_PKGETC}" ]; then
    echo "→ 删除配置: ${TRIM_PKGETC}"
    rm -rf "${TRIM_PKGETC}"
    echo "   ✓ 已删除"
fi

echo ""
echo "✅ 所有数据已清除完毕"
exit 0
